{
  "name": "run-hamster-run",
  "displayName": "Run Hamster Run",
  "icon": "media/activity-icon.png",
  "license": "MIT",
  "description": "The hamster runs on the wheel at your typing speed.",
  "version": "0.1.1",
  "publisher": "soop",
  "repository": {
    "type": "git",
    "url": "https://github.com/miiin/run-hamster-run.git"
  },
  "bugs": {
    "url": "https://github.com/miiin/run-hamster-run/issues"
  },
  "homepage": "https://github.com/miiin/run-hamster-run#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "hamsterRun.view",
          "name": "Hamster",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Run Hamster Run",
      "properties": {
        "hamsterRun.idleThreshold": {
          "type": "number",
          "default": 0.2,
          "description": "이 값 이하의 cps(초당 글자수)에서는 idle 상태로 간주합니다."
        },
        "hamsterRun.windowMs": {
          "type": "number",
          "default": 2000,
          "description": "타자 속도를 계산할 때 사용하는 슬라이딩 윈도우 길이(ms)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
